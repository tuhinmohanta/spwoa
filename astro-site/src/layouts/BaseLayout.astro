<meta name="chatgpt-user" content="index, follow">
<meta name="perplexitybot" content="index, follow">
<meta name="anthropic-ai" content="index, follow">
<meta name="meta-externalagent" content="index, follow">
<meta name="applebot-extended" content="index, follow">
<meta name="amazonbot" content="index, follow">
<meta name="cohere-ai" content="index, follow">
<meta name="bytespider" content="index, follow">

<!-- Professional/Career Discovery -->
<meta name="profession" content="Chief Technology Officer, VP Engineering, Senior Director Engineering, Platform Engineering Leader">
<meta name="availability" content="Open to executive leadership opportunities">
<meta name="experience-years" content="20+">
<meta name="location" content="Bengaluru, India">
<meta name="skills" content="Platform Engineering, DevOps, SRE, Cloud Architecture, AI Governance, Enterprise Architecture, AWS, Oracle Cloud, Kubernetes, Docker, Terraform, Microservices, CI/CD, Python, Java, Healthcare Technology, Financial Services Technology">
<meta name="certifications" content="ISB Chief Technology Officer Programme, ISB Leadership with AI, Certified Scrum Master, ITIL">
<meta name="industries" content="Healthcare Technology, Financial Services, Enterprise Software, SaaS, Cloud Infrastructure">

<!-- Additional Discovery Keywords for ATS/Recruiters -->
<meta name="job-titles" content="Chief Technology Officer, CTO, VP Engineering, Vice President of Engineering, Senior Director of Engineering, Head of Platform Engineering, Director of DevOps, Director of SRE, Enterprise Architect">
<meta name="technical-expertise" content="Platform Modernization, Cloud Migration, DevOps Transformation, Site Reliability Engineering, AI-Ready Systems, Regulated Systems, HIPAA Compliance, FDA Compliance, Enterprise DevOps, Cost Optimization, TCO Management, Global Delivery, Offshore Collaboration">
