<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
<slot name="head" />
</head>
<body>
<div class="ambient">
  <div class="ambient-glow glow-1"></div>
  <div class="ambient-glow glow-2"></div>
</div>

<nav>
  <div class="nav-inner">
    <div class="logo">Tuhin <span>Mohanta</span></div>
    <button class="menu-toggle" onclick="document.querySelector('nav ul').classList.toggle('open')" aria-label="Toggle menu">&#9776;</button>
    <ul>
      <li><a href="/#presence">Presence</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#experience">Journey</a></li>
      <li><a href="/#expertise">Expertise</a></li>
      <li><a href="/media">Writing</a></li>
      <li><a href="/#testimonials">Voices</a></li>
      <li><a href="/#bio">Bio</a></li>
      <li><a href="/#contact">Connect</a></li>
    </ul>
  </div>
</nav>

<slot />

<footer>
  <div class="container">
    <p>© 2026 Tuhin Mohanta · Built with purpose · Bengaluru, India</p>
  </div>
</footer>

<script is:inline>
const nav=document.querySelector('nav');
window.addEventListener('scroll',()=>{nav.classList.toggle('scrolled',window.scrollY>60)});
const observer=new IntersectionObserver(e=>{e.forEach(el=>{if(el.isIntersecting)el.target.classList.add('visible')})},{threshold:.08,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.fade-in,.timeline-item').forEach(el=>observer.observe(el));
const sections=document.querySelectorAll('section[id]');
window.addEventListener('scroll',()=>{const y=window.pageYOffset;sections.forEach(s=>{const t=s.offsetTop-140,h=s.offsetHeight,id=s.getAttribute('id'),l=document.querySelector(`nav a[href="#${id}"], nav a[href="/#${id}"]`);if(l)l.classList.toggle('active',y>=t&&y<t+h)})});
document.querySelectorAll('nav ul a').forEach(a=>{a.addEventListener('click',()=>document.querySelector('nav ul').classList.remove('open'))});
</script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
